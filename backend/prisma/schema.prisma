generator client {
  provider            = "prisma-client"
  output              = "../src/generated/prisma"
  importFileExtension = "ts"
}

datasource db {
  provider = "postgresql"
}

model AdminUser {
  id          Int       @id @default(autoincrement())
  email       String    @unique
  name        String?
  role        String    @default("admin")
  isActive    Boolean   @default(true) @map("is_active")
  googleSub   String?   @unique @map("google_sub")
  lastLoginAt DateTime? @map("last_login_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@map("admin_users")
}

model Employee {
  id             Int             @id @default(autoincrement())
  name           String
  email          String?         @unique
  department     String
  position       String
  isActive       Boolean         @default(true) @map("is_active")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  beacons        Beacon[]
  attendanceLogs AttendanceLog[]

  @@map("employees")
}

model Beacon {
  id             Int             @id @default(autoincrement())
  macAddress     String          @unique @map("mac_address")
  employeeId     Int?            @map("employee_id")
  employee       Employee?       @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  label          String
  isActive       Boolean         @default(true) @map("is_active")
  registeredAt   DateTime        @default(now()) @map("registered_at")
  attendanceLogs AttendanceLog[]

  @@map("beacons")
}

model AttendanceLog {
  id               Int       @id @default(autoincrement())
  employeeId       Int       @map("employee_id")
  employee         Employee  @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  beaconId         Int?      @map("beacon_id")
  beacon           Beacon?   @relation(fields: [beaconId], references: [id], onDelete: SetNull)
  checkIn          DateTime  @map("check_in")
  checkOut         DateTime? @map("check_out")
  date             DateTime  @db.Date
  rssi             Int?
  autoCheckout     Boolean   @default(false) @map("auto_checkout")
  memo             String?
  manualAdjusted   Boolean   @default(false) @map("manual_adjusted")
  manualRegistered Boolean   @default(false) @map("manual_registered")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  @@index([date])
  @@index([employeeId, date])
  @@map("attendance_logs")
}

model SystemConfig {
  key         String   @id
  value       String
  description String?
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("system_config")
}
