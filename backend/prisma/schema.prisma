generator client {
  provider            = "prisma-client"
  output              = "../src/generated/prisma"
  importFileExtension = "ts"
}

datasource db {
  provider = "postgresql"
}

model Employee {
  id         Int      @id @default(autoincrement())
  name       String   @db.VarChar(50)
  email      String?  @unique(map: "employees_email_unique") @db.VarChar(100)
  department String?  @db.VarChar(50)
  position   String?  @db.VarChar(50)
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  meta       String?  @db.VarChar(50)
  beacons    Beacon[]

  @@map("employees")
}

model Beacon {
  id           Int       @id @default(autoincrement())
  macAddress   String    @unique(map: "beacons_mac_address_unique") @map("mac_address") @db.VarChar(17)
  employeeId   Int?      @map("employee_id")
  label        String?   @db.VarChar(50)
  isActive     Boolean   @default(true) @map("is_active")
  registeredAt DateTime  @default(now()) @map("registered_at") @db.Timestamptz(6)
  employee     Employee? @relation(fields: [employeeId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "beacons_employee_id_employees_id_fk")

  @@map("beacons")
}

model SystemConfig {
  key         String   @id @db.VarChar(50)
  value       String   @db.VarChar(200)
  description String?  @db.VarChar(200)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("system_config")
}

model beacon_detections {
  id          BigInt   @id @default(autoincrement())
  device_id   String   @db.VarChar(20)
  mac_address String   @db.VarChar(17)
  rssi        Int      @db.SmallInt
  detected_at DateTime @db.Timestamptz(6)
  received_at DateTime @default(now()) @db.Timestamptz(6)
  devices     devices  @relation(fields: [device_id], references: [device_id], onDelete: NoAction, onUpdate: NoAction, map: "beacon_detections_device_id_devices_device_id_fk")

  @@index([device_id, detected_at], map: "idx_detections_device_detected")
  @@index([mac_address, detected_at], map: "idx_detections_mac_detected")
}

model devices {
  device_id         String              @id @db.VarChar(20)
  location_label    String              @db.VarChar(50)
  api_key_hash      String              @db.VarChar(255)
  firmware_version  String?             @db.VarChar(20)
  last_heartbeat_at DateTime?           @db.Timestamptz(6)
  is_active         Boolean             @default(true)
  registered_at     DateTime            @default(now()) @db.Timestamptz(6)
  beacon_detections beacon_detections[]
}

model users {
  id            Int       @id @default(autoincrement())
  email         String    @unique(map: "users_email_unique") @db.VarChar(100)
  name          String?   @db.VarChar(100)
  role          String    @default("viewer") @db.VarChar(20)
  is_active     Boolean   @default(true)
  created_at    DateTime  @default(now()) @db.Timestamptz(6)
  last_login_at DateTime? @db.Timestamptz(6)
}
